{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zotero",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": ["nodejs_compat"],
  "base_dir": ".",
  "find_additional_modules": true,
  "preserve_file_names": true,
  "rules": [
    {
      "type": "CompiledWasm",
      "globs": [
        "node_modules/bsdiff-wasm/dist/*.wasm",
        "node_modules/xdelta3-wasm/dist/*.wasm"
      ],
      "fallthrough": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "secrets": {
    "required": ["SELFHOST_TEST_API_KEY"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zotero",
      "database_id": "812b7410-fd86-4e26-906a-0d960390fee6",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "zotero-attachments"
    }
  ]
}
