# One-time Zotero.org source credential. Read locally by
# `zotero-selfhost import`; never uploaded to the Worker or import state.
ZOTERO_IMPORT_API_KEY=

# Owner credential for the self-host target. This is also local-only. Prefer a
# password-manager shell integration or the CLI's --api-key-file option.
SELFHOST_API_KEY=
