# Local Worker runtime, desktop smoke, compatibility harness, and Wrangler auth.
# Copy this file to server/.env; do not commit real values.

SELFHOST_TEST_API_KEY=
RAW_FILE_URL_SECRET=
ROOT_USERNAME=root
ROOT_PASSWORD=local-root-password
TTS_TEST_KEY=

# Optional future importer input; not used by the current selfhost runtime.
ZOTERO_IMPORT_API_KEY=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_TOKEN_ID=
