# Production Worker secret. The setup CLI generates and uploads this value;
# Deploy-to-Cloudflare users are prompted for it.
FILE_URL_SIGNING_SECRET=

# Direct attachment uploads use a dedicated R2 Object Read & Write token scoped
# only to zotero-selfhost-attachments. Cloudflare shows these values once when
# the R2 token is created; setup installs them as Worker secrets.
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
