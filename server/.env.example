# Production Worker configuration. The setup CLI generates and uploads the signing secret; Deploy-to-Cloudflare users are prompted for it.
FILE_URL_SIGNING_SECRET=

# Direct attachment uploads use a dedicated R2 Object Read & Write token scoped only to zotero-selfhost-attachments. Cloudflare shows these values once when the R2 token is created; setup installs them as Worker secrets.
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Local CLI credentials. These values remain on the operator's machine and are never uploaded to the Worker or written into import state.
SELFHOST_API_KEY=
ZOTERO_IMPORT_API_KEY=

# Isolated compatibility deployment only. Never install these values on the production Worker or point this deployment at production D1 or R2 resources.
DEPLOYMENT_MODE=compatibility-test
COMPATIBILITY_TEST_ADMIN_TOKEN=
COMPATIBILITY_TEST_API_KEY=
TTS_TEST_KEY=
SELFHOST_URL=http://127.0.0.1:8787
